{
  "name": "phpvm",
  "version": "2.0.0",
  "description": "PHP Version Manager - Manage multiple PHP versions easily",
  "main": "index.js",
  "scripts": {
    "setup": "node setup.js",
    "build": "pkg . --compress Brotli --output phpvm.exe",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "php",
    "version-manager",
    "nvm",
    "windows"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "axios": "^1.14.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "ora": "^9.3.0",
    "unzipper": "^0.12.3"
  },
  "bin": {
    "phpvm": "./bin/phpvm.js",
    "phpvm-setup": "./setup.js"
  },
  "pkg": {
    "scripts": [
      "./bin/phpvm.js",
      "./setup.js"
    ],
    "assets": [
      "node_modules/"
    ],
    "targets": [
      "win-x64"
    ],
    "outputPath": "dist"
  }
}
